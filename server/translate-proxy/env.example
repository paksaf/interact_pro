# /etc/interact/translate.env
# Mode: 0640, owned by root:interact (or whichever user systemd runs as).
# Never commit the real file — this template is the only thing in git.

# Required. The DeepSeek API key the proxy will inject server-side.
DEEPSEEK_API_KEY=sk-replace-me

# Required if you want to gate the proxy by app token. Generate with:
#   openssl rand -hex 32
# Pass the same value to the Flutter app via --dart-define=APP_TRANSLATE_TOKEN=...
# Leave empty to disable token auth (only do that if the box is firewalled).
# The current production value lives in server/translate-proxy/secrets.local.md
# (gitignored). Sync that into /etc/interact/translate.env on the box.
APP_SHARED_SECRET=

# Loopback port the Node service binds to. Caddy/nginx reverse-proxies to this.
PORT=8081

# Per-IP rate limit (requests per minute). Bump for production traffic.
RATE_LIMIT_PER_MIN=60

# Hard cap on input characters across all messages. Cheap protection
# against bill-runaway from a malicious client sending huge blobs.
MAX_INPUT_CHARS=8000

# Comma-separated allowlist of model names the proxy will accept. The app
# sends "deepseek-chat" today; add others as you adopt them.
ALLOWED_MODELS=deepseek-chat,deepseek-reasoner

# ── Usage logging ────────────────────────────────────────────────────────
# Append-only NDJSON log of every successful translate request, used by
# the weekly usage-report.js cron. Empty disables logging entirely.
USAGE_LOG_PATH=/var/log/interact/translate-usage.ndjson

# ── Weekly usage email (consumed by usage-report.js, not index.js) ───────
# SMTP relay credentials. Most Hetzner Mailbox / Gmail / Resend setups work.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
USAGE_FROM=interact-proxy@interactpak.com
USAGE_TO=interact@paksaf.com
USAGE_SUBJECT_PREFIX=[Interact Pro] Translate proxy usage
