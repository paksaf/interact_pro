# /etc/interact/pro-api.env on the VPS — copy from this file, fill in
# the blanks, chown root:interact 640. systemd unit reads it via
# EnvironmentFile=. NEVER commit a filled-in copy.

# ── Postgres ────────────────────────────────────────────────────────────
# Local Postgres on the same VPS, separate database from the other apps.
# Create it with:
#   sudo -u postgres psql -c "CREATE USER interactpro WITH PASSWORD '...';"
#   sudo -u postgres psql -c "CREATE DATABASE interactpro OWNER interactpro;"
DATABASE_URL=postgres://interactpro:CHANGEME@127.0.0.1:5432/interactpro

# ── JWT signing ─────────────────────────────────────────────────────────
# At least 32 chars. Generate fresh with:
#   openssl rand -base64 48
JWT_SECRET=CHANGEME_at_least_32_random_chars

# How long an issued JWT is valid. 30 days = 2592000 seconds.
JWT_TTL_SECONDS=2592000

# ── Email OTPs (Resend) ─────────────────────────────────────────────────
# The same key already used for the weekly translate-proxy usage email.
RESEND_API_KEY=re_CHANGEME

OTP_MAIL_FROM=Interact Pro <noreply@send.interactpak.com>
OTP_MAIL_REPLY_TO=interact@paksaf.com

# ── SMS OTPs (Dexatel) ──────────────────────────────────────────────────
# The same key used by Qurbani Sahulat / Movento / FleetOps for SMS.
# Leave blank in dev — sms.js will log to stdout instead of sending.
DEXATEL_API_KEY=
DEXATEL_SENDER=InteractPro

# ── Behaviour ───────────────────────────────────────────────────────────
PORT=3050
TRIAL_DAYS=7
OTP_TTL_MIN=10
PG_POOL_MAX=10
